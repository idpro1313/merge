from __future__ import annotations

import logging
from dataclasses import dataclass
from typing import Generic, TypeVar


logger = logging.getLogger(__name__)
T = TypeVar("T")


# START_CLASS_Result
# START_CONTRACT: Result
#   PURPOSE: Унифицированный результат операции модуля.
#   INPUTS: поля dataclass.
#   OUTPUTS: экземпляр Result.
#   SIDE_EFFECTS: нет.
#   LINKS: $GRAPH_LINKS
# END_CONTRACT: Result
@dataclass(frozen=True)
class Result(Generic[T]):
    ok: bool
    value: T | None = None
    error: str | None = None


# END_CLASS_Result


# START_METHOD__log_grace_marker
# START_CONTRACT: _log_grace_marker
#   PURPOSE: Печать стабильного GRACE-маркера для трассировки.
#   INPUTS: marker, fields
#   OUTPUTS: None
#   SIDE_EFFECTS: logger.info
#   LINKS: $GRAPH_LINKS
# END_CONTRACT: _log_grace_marker
def _log_grace_marker(marker: str, **fields: object) -> None:
    # Замените на проектный логгер. Маркер должен оставаться стабильным для проверки.
    logger.info("%s %s", marker, fields)


# END_METHOD__log_grace_marker


# START_METHOD_$EXPORTED_SYMBOL
# START_CONTRACT: $EXPORTED_SYMBOL
#   PURPOSE: $FUNCTION_PURPOSE
#   INPUTS: { input_value: $INPUT_TYPE - $INPUT_DESCRIPTION }
#   OUTPUTS: { Result[$OUTPUT_TYPE] - $OUTPUT_DESCRIPTION }
#   SIDE_EFFECTS: Пишет стабильный GRACE log-marker.
#   LINKS: $FUNCTION_LINKS
# END_CONTRACT: $EXPORTED_SYMBOL
def $EXPORTED_SYMBOL(input_value: $INPUT_TYPE) -> Result[$OUTPUT_TYPE]:
    """Выполняет основное преобразование модуля согласно GRACE-контракту."""

    # START_BLOCK_VALIDATE_INPUT
    if input_value is None:
        _log_grace_marker(
            "[$MODULE_NAME][$EXPORTED_SYMBOL][BLOCK_VALIDATE_INPUT] invalid input",
            reason="INPUT_REQUIRED",
        )
        return Result(ok=False, error="INPUT_REQUIRED")
    # END_BLOCK_VALIDATE_INPUT

    # START_BLOCK_BUILD_RESULT
    value = input_value
    _log_grace_marker(
        "[$MODULE_NAME][$EXPORTED_SYMBOL][BLOCK_BUILD_RESULT] result built",
        status="ok",
    )
    # END_BLOCK_BUILD_RESULT
    return Result(ok=True, value=value)


# END_METHOD_$EXPORTED_SYMBOL
