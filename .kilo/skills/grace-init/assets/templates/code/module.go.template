package $PACKAGE_NAME

import (
	"errors"
	"fmt"
)

// START_CLASS_Result
// START_CONTRACT: Result
//   PURPOSE: Унифицированный результат операции модуля.
//   INPUTS: поля struct.
//   OUTPUTS: Result value.
//   SIDE_EFFECTS: нет.
//   LINKS: $GRAPH_LINKS
// END_CONTRACT: Result
type Result struct {
	OK    bool
	Value $OUTPUT_TYPE
	Error string
}

// END_CLASS_Result

// START_METHOD_logGraceMarker
// START_CONTRACT: logGraceMarker
//   PURPOSE: Печать стабильного GRACE-маркера.
//   INPUTS: marker, fields
//   OUTPUTS: нет
//   SIDE_EFFECTS: fmt.Printf
//   LINKS: $GRAPH_LINKS
// END_CONTRACT: logGraceMarker
func logGraceMarker(marker string, fields map[string]any) {
	// Замените на проектный логгер. Маркер должен оставаться стабильным для проверки.
	fmt.Printf("%s %v\n", marker, fields)
}

// END_METHOD_logGraceMarker

// START_METHOD_$EXPORTED_SYMBOL
// START_CONTRACT: $EXPORTED_SYMBOL
//   PURPOSE: $FUNCTION_PURPOSE
//   INPUTS: { input: $INPUT_TYPE - $INPUT_DESCRIPTION }
//   OUTPUTS: { Result - $OUTPUT_DESCRIPTION }
//   SIDE_EFFECTS: Пишет стабильный GRACE log-marker.
//   LINKS: $FUNCTION_LINKS
// END_CONTRACT: $EXPORTED_SYMBOL
func $EXPORTED_SYMBOL(input $INPUT_TYPE) (Result, error) {
	// START_BLOCK_VALIDATE_INPUT
	if $INVALID_INPUT_CONDITION {
		logGraceMarker("[$MODULE_NAME][$EXPORTED_SYMBOL][BLOCK_VALIDATE_INPUT] invalid input", map[string]any{
			"reason": "INPUT_REQUIRED",
		})
		return Result{OK: false, Error: "INPUT_REQUIRED"}, errors.New("INPUT_REQUIRED")
	}
	// END_BLOCK_VALIDATE_INPUT

	// START_BLOCK_BUILD_RESULT
	logGraceMarker("[$MODULE_NAME][$EXPORTED_SYMBOL][BLOCK_BUILD_RESULT] result built", map[string]any{
		"status": "ok",
	})
	// END_BLOCK_BUILD_RESULT
	return Result{OK: true, Value: $BUILD_VALUE}, nil
}

// END_METHOD_$EXPORTED_SYMBOL
