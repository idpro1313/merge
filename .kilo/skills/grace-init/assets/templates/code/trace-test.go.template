// FILE: $TEST_PATH
// VERSION: 0.1.0
// START_MODULE_CONTRACT
//   PURPOSE: Проверяет детерминированный результат и GRACE trace evidence для $MODULE_NAME.
//   SCOPE: $SCENARIO_NAME
//   DEPENDS: $MODULE_UNDER_TEST
//   LINKS: $VERIFICATION_REF
// END_MODULE_CONTRACT
//
// START_MODULE_MAP
//   Test$SCENARIO_ID - Проверяет результат и обязательные trace markers.
// END_MODULE_MAP
//
// START_CHANGE_SUMMARY
//   LAST_CHANGE: v0.1.0 - Первичный каркас Go trace-test проверки.
// END_CHANGE_SUMMARY

package $PACKAGE_NAME

import "testing"

// START_METHOD_Test$SCENARIO_ID
// START_CONTRACT: Test$SCENARIO_ID
//   PURPOSE: Доказывает, что результат сценария и путь выполнения соответствуют verification plan.
//   INPUTS: { фикстуры и захваченные маркеры }
//   OUTPUTS: { свидетельство успешного или неуспешного прохождения }
//   SIDE_EFFECTS: нет, кроме локальных фикстур теста
//   LINKS: $VERIFICATION_REF
// END_CONTRACT: Test$SCENARIO_ID
func Test$SCENARIO_ID(t *testing.T) {
	// START_BLOCK_EXECUTE_SCENARIO
	capturedMarkers := []string{}
	result := $CALL_MODULE_UNDER_TEST
	// END_BLOCK_EXECUTE_SCENARIO

	// START_BLOCK_ASSERT_OUTCOME
	if result != $EXPECTED_RESULT {
		t.Fatalf("unexpected result: %v", result)
	}
	// END_BLOCK_ASSERT_OUTCOME

	// START_BLOCK_ASSERT_TRACE
	requiredFound := false
	for _, marker := range capturedMarkers {
		if marker == "$REQUIRED_MARKER" {
			requiredFound = true
		}
		if marker == "$FORBIDDEN_MARKER" {
			t.Fatalf("forbidden marker emitted: %s", marker)
		}
	}
	if !requiredFound {
		t.Fatalf("required marker not emitted: %s", "$REQUIRED_MARKER")
	}
	// END_BLOCK_ASSERT_TRACE
}

// END_METHOD_Test$SCENARIO_ID
