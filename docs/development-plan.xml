<DevelopmentPlan VERSION="0.1.0">
  <Phases>
    <Phase-1 name="Foundation" status="done">
      <description>Инициализация проекта, GRACE-структура, базовая архитектура</description>
      <modules>
        <ref>M-CONFIG</ref>
        <ref>M-TYPES</ref>
        <ref>M-BOARD_LOGIC</ref>
        <ref>M-LEVELS</ref>
      </modules>
      <deliverables>
        <item>GRACE docs (requirements, technology, knowledge-graph)</item>
        <item>Типы игрового движка и константы</item>
        <item>Чистые функции управления доской</item>
        <item>Утилиты стилей уровней</item>
      </deliverables>
    </Phase-1>

    <Phase-2 name="Backend" status="done">
      <description>Express-сервер, SQLite, аутентификация, API-роуты</description>
      <modules>
        <ref>M-DB</ref>
        <ref>M-AUTH</ref>
        <ref>M-BACKEND_ROUTES</ref>
        <ref>M-BACKEND_ENTRY</ref>
      </modules>
      <deliverables>
        <item>Инициализация SQLite с таблицами users, saves, stats</item>
        <item>Аутентификация через Telegram initData + JWT</item>
        <item>REST API: /api/auth/login, /api/game/save, /api/game/load, /api/leaderboard, /api/users/me</item>
        <item>Express entry point с CORS и JSON middleware</item>
      </deliverables>
    </Phase-2>

    <Phase-3 name="Frontend" status="done">
      <description>React-приложение, игровой UI, хуки управления состоянием</description>
      <modules>
        <ref>M-API</ref>
        <ref>M-USE_GAME</ref>
        <ref>M-COMPONENTS</ref>
        <ref>M-APP</ref>
        <ref>M-MAIN_ENTRY</ref>
      </modules>
      <deliverables>
        <item>API клиент (login, save, load, leaderboard)</item>
        <item>Хук useGame с логикой тапов и слияния</item>
        <item>Компоненты: Board, Cell, ScoreBar, ActionBar, Leaderboard</item>
        <item>Корневой App с аутентификацией через Telegram</item>
        <item>Точка входа main.tsx</item>
      </deliverables>
    </Phase-3>

    <Phase-4 name="Bot" status="done">
      <description>Telegram-бот для /start и /top</description>
      <modules>
        <ref>M-BOT</ref>
      </modules>
      <deliverables>
        <item>Обработчик /start с inline-кнопкой Mini App</item>
        <item>Обработчик /top с таблицей лидеров</item>
      </deliverables>
    </Phase-4>

    <Phase-5 name="Bugfixes+GRACE" status="current">
      <description>Исправление найденных багов, добавление GRACE-разметки во все файлы</description>
      <modules>
        <ref>M-DB</ref>
        <ref>M-AUTH</ref>
        <ref>M-BACKEND_ROUTES</ref>
        <ref>M-BOARD_LOGIC</ref>
        <ref>M-TYPES</ref>
        <ref>M-USE_GAME</ref>
        <ref>M-API</ref>
        <ref>M-COMPONENTS</ref>
        <ref>M-APP</ref>
        <ref>M-BOT</ref>
      </modules>
      <tasks>
        <task-1>Fix SQL trailing commas in db.ts</task-1>
        <task-2>Fix SQL quoting in leaderboard.ts</task-2>
        <task-3>Fix FK mismatch in auth.ts (stats.user_id)</task-3>
        <task-4>Add MODULE_CONTRACT/MAP/METHOD/BLOCK to all source files</task-4>
      </tasks>
    </Phase-5>

    <Phase-6 name="Testing" status="planned">
      <description>Модульные тесты для core-логики и API-эндпоинтов</description>
      <tasks>
        <task-1>Тесты board.ts (create, spawn, remove, merge)</task-1>
        <task-2>Тесты levels.ts (цвета для уровней)</task-2>
        <task-3>Тесты API (auth, game save/load, leaderboard)</task-3>
      </tasks>
    </Phase-6>
  </Phases>

  <DataFlows>
    <DF-001 name="Auth Flow">
      <steps>
        <step-1>Frontend получает initData от Telegram.WebApp</step-1>
        <step-2>POST /api/auth/login с initData</step-2>
        <step-3>Backend верифицирует HMAC-SHA256 подпись</step-3>
        <step-4>Создаёт или находит пользователя в SQLite</step-4>
        <step-5>Возвращает JWT токен (7 дней)</step-5>
      </steps>
    </DF-001>

    <DF-002 name="Game Save/Load Flow">
      <steps>
        <step-1>Игрок нажимает Save или игра автосохраняется</step-1>
        <step-2>POST /api/game/save с board, score, maxLevel</step-2>
        <step-3>Backend upsert в таблицу saves, обновляет top_score</step-3>
        <step-4>GET /api/game/load возвращает сохранённое состояние</step-4>
      </steps>
    </DF-002>

    <DF-003 name="Leaderboard Flow">
      <steps>
        <step-1>Игрок открывает Leaderboard</step-1>
        <step-2>GET /api/leaderboard</step-2>
        <step-3>Backend возвращает топ-20 по top_score</step-3>
        <step-4>Frontend отображает модальное окно</step-4>
      </steps>
    </DF-003>
  </DataFlows>

  <WriteScopes>
    <scope agent="controller" path="docs/*.xml" description="GRACE artifacts" />
    <scope agent="controller" path="*.md, AGENTS.md" description="Project documentation" />
    <scope agent="controller" path="backend/src/**/*.ts" description="Backend source" />
    <scope agent="controller" path="frontend/src/**/*.{ts,tsx}" description="Frontend source" />
    <scope agent="controller" path="bot/src/**/*.ts" description="Bot source" />
  </WriteScopes>
</DevelopmentPlan>